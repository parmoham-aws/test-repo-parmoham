#!/bin/bash
# Run tests for torch-neuronx in parallel using multiple neuron devices
# Each test worker will automatically be assigned a unique neuron device

set -e

# Configuration
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
readonly DEFAULT_IGNORE_DIRS=("tests/tmp" "tests/huggingface" "tests/pytorch_tests" "tests/cpu_fallback" "tests/vertical")
readonly SKIP_TESTS=("tests/distributed/" "tests/device/test_multi_device.py" "tests/device/test_device_lnc1_all_cores.py")
readonly REQUIRED_PACKAGES=("pytest_html" "xdist" "pytest_forked")

# Global state
declare -g RUNNER=()
declare -g PYTEST_ARGS=""
declare -g NUM_WORKERS=0
declare -g REPORTS_DIR=""
declare -g CUSTOM_NUM_WORKERS=""
declare -g exit_code=0

# Flags
declare -g CUSTOM_N=false
declare -g SKIP_DISTRIBUTED=false
declare -g SKIP_VERTICAL=true
declare -g ENABLE_COVERAGE=false
declare -g ENABLE_JSON_REPORT=false
declare -g HAS_EXPLICIT_TEST_PATH=false
declare -g SKIP_PT_TEST_DISTRIBUTED=false
declare -g SANITY_PT_DISTRIBUTED_TESTS=""


# Initialize environment
init_environment() {
    cd "$PROJECT_ROOT"
    export NEURON_LAUNCH_BLOCKING="${NEURON_LAUNCH_BLOCKING:-0}"

    if command -v uv >/dev/null 2>&1; then
        RUNNER=(uv run python)
    else
        RUNNER=(python)
    fi
}

# Check if package is available
check_package() {
    local package="$1"
    "${RUNNER[@]}" -c "import ${package//-/_}" >/dev/null 2>&1
}

# Validate dependencies
validate_dependencies() {
    local missing_packages=()

    for package in "${REQUIRED_PACKAGES[@]}"; do
        if ! check_package "$package"; then
            # Convert Python import name to pip package name
            missing_packages+=("pytest-${package#pytest_}")
        fi
    done

    if [[ "$ENABLE_COVERAGE" == "true" ]] && ! check_package "pytest_cov"; then
        missing_packages+=("pytest-cov")
    fi

    if [[ "$ENABLE_JSON_REPORT" == "true" ]] && ! check_package "pytest_json_report"; then
        missing_packages+=("pytest-json-report")
    fi

    if [[ ${#missing_packages[@]} -ne 0 ]]; then
        echo "Error: Missing required packages: ${missing_packages[*]}" >&2
        echo "Please install: pip install ${missing_packages[*]}" >&2
        exit 1
    fi
}

# Get neuron core count
get_neuron_cores() {
    local cores
    cores=$("${RUNNER[@]}" -c "
import json
import subprocess
from torch_neuronx.utils import get_worker_multiplier

result = subprocess.run(['/opt/aws/neuron/bin/neuron-ls', '-j'],
                       capture_output=True, text=True, check=True)
devices = json.loads(result.stdout)
total_cores = sum(device['nc_count'] for device in devices)
multiplier = get_worker_multiplier()
print(total_cores * multiplier)
")

    if [[ ! "$cores" =~ ^[0-9]+$ ]] || [[ "$cores" -eq 0 ]]; then
        echo "Error: Could not detect neuron cores" >&2
        exit 1
    fi

    NUM_WORKERS="$cores"
}

# Parse command line arguments
parse_arguments() {
    local i=0
    local args=("$@")

    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[$i]}"
        case "$arg" in
            "-n") CUSTOM_N=true ;;
            "--skip-distributed") SKIP_DISTRIBUTED=true ;;
            "--include-vertical") SKIP_VERTICAL=false ;;
            "--coverage") ENABLE_COVERAGE=true ;;
            "--json-report") ENABLE_JSON_REPORT=true ;;
            "--skip_pt_test_distributed") SKIP_PT_TEST_DISTRIBUTED=true ;;
            "--sanity_pt_distributed_tests")
                SANITY_PT_DISTRIBUTED_TESTS="--sanity_pt_distributed_tests"
                ;;
            "--num_workers")
                i=$((i + 1))
	            [[ $i -lt ${#args[@]} ]] || { echo "Error: --num_workers requires a number argument" >&2; exit 1; }
	            CUSTOM_NUM_WORKERS="${args[$i]}"
                ;;
	            --num_workers=*) CUSTOM_NUM_WORKERS="${arg#--num_workers=}" ;;
            "--report-dir")
                i=$((i + 1))
                [[ $i -lt ${#args[@]} ]] || { echo "Error: --report-dir requires a directory argument" >&2; exit 1; }
                REPORTS_DIR="${args[$i]}"
                ;;
            --report-dir=*) REPORTS_DIR="${arg#--report-dir=}" ;;
            -*) PYTEST_ARGS="$PYTEST_ARGS $arg" ;;
            *) handle_test_path "$arg" ;;
        esac
        i=$((i + 1))
    done
}

# Handle test path normalization
handle_test_path() {
    local arg="$1"
    local norm_path

    if [[ ! "$arg" =~ ^tests/ ]]; then
        norm_path="tests/$arg"
    else
        norm_path="$arg"
    fi

    PYTEST_ARGS="$PYTEST_ARGS $norm_path"

    if [[ ! "$norm_path" =~ ^tests/?$ ]]; then
        HAS_EXPLICIT_TEST_PATH=true
    fi
}

# Build ignore arguments
build_ignore_args() {
    local ignore_args=""

    for dir in "${DEFAULT_IGNORE_DIRS[@]}"; do
        ignore_args+="--ignore=$dir "
    done

    # Add multi-device and distributed test ignores for full suite runs
    if [[ "$HAS_EXPLICIT_TEST_PATH" == "false" ]]; then
        for test in "${SKIP_TESTS[@]}"; do
            ignore_args+="--ignore=$test "
        done
    fi

    echo "$ignore_args"
}
# Setup test reports directory and options
setup_reports() {
    if [[ -z "$REPORTS_DIR" ]]; then
        REPORTS_DIR="$PROJECT_ROOT/test-reports"
    fi
    mkdir -p "$REPORTS_DIR"
}

# Build pytest command options
build_pytest_options() {
    local report_name="${1:-report}"
    local workers="${2:-$NUM_WORKERS}"

    local html_opts="--html=$REPORTS_DIR/${report_name}.html --self-contained-html --tb=short"
    local cov_opts=""
    local xdist_args=""
    local json_report_ops=""

    if [[ "$ENABLE_COVERAGE" == "true" && "$report_name" == "report" ]]; then
        local cov_target="torch_neuronx"
        cov_opts="--cov=$cov_target --cov-report=html:$REPORTS_DIR/coverage --cov-report=term-missing --cov-append"
        if [[ "$ENABLE_JSON_REPORT" == "true" ]]; then
            # Add JSON coverage report in addition to HTML
            cov_opts+=" --cov-report=json:$REPORTS_DIR/json_reports/coverage.json"
        fi
    fi

    if [[ "$ENABLE_JSON_REPORT" == "true" ]]; then
        json_report_ops="--json-report --json-report-file=$REPORTS_DIR/json_reports/${report_name}.json"
    fi

    if [[ "$CUSTOM_N" == "false" ]]; then
        xdist_args="-n $workers"
    fi

    echo "$xdist_args $html_opts $cov_opts $json_report_ops"
}

# Run command and track exit code
run_and_record() {
    local test_name="$1"
    local cmd="$2"
    echo "Running $test_name: $cmd"
    if ! eval "$cmd"; then
        exit_code=1
    fi
}

run_distributed_test_type() {
    local test_name="$1"
    local report_name="$2"
    local test_file="$3"
    local n="$4"
    local pytest_opts
    pytest_opts=$(build_pytest_options "$report_name" "$n")

    run_and_record "$test_name" "export DISTRIBUTED_TESTS_DEFAULT_TIMEOUT=1200 && ${RUNNER[*]} -m pytest --forked $pytest_opts $SANITY_PT_DISTRIBUTED_TESTS tests/pytorch_tests/distributed/$test_file"
}

# Run main test suite
run_main_tests() {
    local ignore_args
    local pytest_opts
    local test_args="$PYTEST_ARGS"
    local workers="$NUM_WORKERS"

    ignore_args=$(build_ignore_args)

    # Set default test path if none provided
    if [[ ! "$test_args" =~ tests/ ]]; then
        test_args="tests"
    fi

    if [[ -n "$CUSTOM_NUM_WORKERS" && "$HAS_EXPLICIT_TEST_PATH" == "true" ]]; then
	    workers="$CUSTOM_NUM_WORKERS"
	fi
	pytest_opts=$(build_pytest_options "report" "$workers")

    local cmd="${RUNNER[*]} -m pytest --forked $pytest_opts $test_args $ignore_args"
    run_and_record "main_tests" "$cmd"
}

# Run additional tests
run_additional_tests() {
    if [[ "$HAS_EXPLICIT_TEST_PATH" == "true" ]]; then
        return
    fi

    if [[ "$SKIP_DISTRIBUTED" == "false" ]]; then
        local distributed_workers=$((NUM_WORKERS / 8))
        [[ $distributed_workers -lt 1 ]] && distributed_workers=1

        local pytest_opts
        pytest_opts=$(build_pytest_options "distributed-report" "$distributed_workers")
        run_and_record "distributed_tests" "${RUNNER[*]} -m pytest --forked $pytest_opts tests/distributed"
    fi

    local pytest_opts
    pytest_opts=$(build_pytest_options "multi-device-report" "1")
    run_and_record "multi_device_tests" "${RUNNER[*]} -m pytest --forked $pytest_opts tests/device/test_multi_device.py"

    # LNC=1 + all cores test (requires special env vars, runs with all cores visible)
    local pytest_opts
    pytest_opts=$(build_pytest_options "lnc1-all-cores-report" "1")
    run_and_record "lnc1_all_cores_tests" "NEURON_LOGICAL_NC_CONFIG=1 ${RUNNER[*]} -m pytest --forked $pytest_opts tests/device/test_device_lnc1_all_cores.py"

    local pytest_opts
    pytest_opts=$(build_pytest_options "cpu-fallback-report" "$NUM_WORKERS")
    run_and_record "cpu_fallback_tests" "TORCH_NEURONX_FALLBACK_ONLY_FOR_UNIMPLEMENTED_OPS=0 ${RUNNER[*]} -m pytest --forked $pytest_opts tests/cpu_fallback/test_cpu_fallback.py"

    if [[ "$SKIP_VERTICAL" == "false" ]]; then
        local pytest_opts
        pytest_opts=$(build_pytest_options "vertical-report" "$NUM_WORKERS")
        run_and_record "vertical_tests" "${RUNNER[*]} -m pytest --forked $pytest_opts tests/vertical"
    fi

    local pytest_opts
    pytest_opts=$(build_pytest_options "streams-report" "$NUM_WORKERS")
    run_and_record "streams_tests" "${RUNNER[*]} -m pytest --forked $pytest_opts tests/streams"

    # PyTorch tests with fixed worker count
    if [[ "$SKIP_PT_TEST_DISTRIBUTED" != "true" ]]; then
        # Get installed torch version
        local torch_version
        if command -v uv >/dev/null 2>&1; then
            torch_version=$(uv pip list | grep "^torch " | awk '{print $2}' | cut -d'+' -f1)
        else
            torch_version=$(pip list | grep "^torch " | awk '{print $2}' | cut -d'+' -f1)
        fi

        # Fallback if detection fails
        if [[ -z "$torch_version" ]]; then
            torch_version="2.10.0"
            echo "Warning: Could not detect torch version, using fallback: $torch_version"
        else
            echo "Detected torch version: $torch_version"
        fi

        python tests/pytorch_tests/clone_tests.py --torch-version "$torch_version"

        local -a test_files=(
            "test_dtensor.py"
            "test_dtensor_tp.py"
            "test_checkpoint.py"
            "test_common_c10d.py"
            "test_ddp.py"
        )

        if [[ "$NEURON_LAUNCH_BLOCKING" == "1" ]]; then
            test_files+=("test_fsdp.py")
        fi
        test_files+=("fsdp_v2/")

        # Run each test configuration
        for test_file in "${test_files[@]}"; do
            local test_path="tests/pytorch_tests/distributed/$test_file"

            local base_name="${test_file#test_}"  # Remove "test_" prefix
            base_name="${base_name%.py}"          # Remove ".py" suffix
            local test_name="pytorch_${base_name}_tests"
            local report_name="pytorch-${base_name//_/-}-report"

            local display_name="${base_name^^}"
            display_name="${display_name//_/ }"
            echo "Running PyTorch ${display_name} Tests: $REPORTS_DIR/${report_name}.html"
            run_distributed_test_type "$test_name" "$report_name" "$test_file" "8"
        done
    fi
}

# Display test results summary
display_results() {
    echo ""
    echo "========================================="
    echo "Test Reports Generated:"
    echo "========================================="
    echo "Main Report: $REPORTS_DIR/report.html"

    if [[ "$ENABLE_COVERAGE" == "true" ]]; then
        echo "Coverage Report: $REPORTS_DIR/coverage/index.html"
    fi

    if [[ "$ENABLE_JSON_REPORT" == "true" ]]; then
        echo "Pytest JSON Report: $REPORTS_DIR/json_reports/report.json"
        echo "Coverage JSON Report: $REPORTS_DIR/json_reports/coverage.json"
    fi

    if [[ "$HAS_EXPLICIT_TEST_PATH" == "false" ]]; then
        if [[ "$SKIP_DISTRIBUTED" == "false" ]]; then
            echo "Distributed Tests: $REPORTS_DIR/distributed-report.html"
        fi
        echo "Multi-Device Tests: $REPORTS_DIR/multi-device-report.html"
        if [[ "$SKIP_VERTICAL" == "false" ]]; then
            echo "Vertical Tests: $REPORTS_DIR/vertical-report.html"
        fi
    fi

    echo "========================================="
}

# Main execution
main() {
    init_environment
    parse_arguments "$@"
    validate_dependencies
    get_neuron_cores
    setup_reports

    echo "Note: Each test worker will be assigned a unique neuron device"
    if [[ "$CUSTOM_N" == "false" ]]; then
        echo "Using $NUM_WORKERS parallel workers"
    fi

    # Clear previous coverage data
    coverage erase

    run_main_tests
    run_additional_tests
    display_results

    exit $exit_code
}

main "$@"

