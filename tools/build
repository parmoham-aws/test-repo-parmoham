#!/bin/bash

# Build torch-neuronx extension
echo "Building torch-neuronx..."

# Decide how to run python (prefer uv if available)
if [ -n "$VIRTUAL_ENV" ]; then # no need to explicitly call uv run if we're in venv
    RUNNER=(python)
elif command -v uv >/dev/null 2>&1; then
    RUNNER=(uv run python)
else
    RUNNER=(python)
fi

# Run build quietly and suppress stdout (but keep stderr for errors)
# Builds with Bazel by default.
# To build with CMake, use this command:
# USE_CMAKE=1 "${RUNNER[@]}" setup.py build_ext --quiet --inplace
# To build with PyTorch C++ Extension, remove CMake/Bazel env var:
# "${RUNNER[@]}" setup.py build_ext --quiet --inplace
if ! USE_BAZEL=1 "${RUNNER[@]}" setup.py build_ext --quiet > /dev/null; then
    echo "Build failed! Running verbose build to show errors..."
    USE_BAZEL=1 "${RUNNER[@]}" setup.py build_ext
    exit 1
fi

# Generate wheel after build (optional)
if [[ "$1" == "--wheel" ]]; then
    echo "Generating wheel..."
    RELEASE_FLAG=""
    if [[ "$2" == "release" ]]; then
        RELEASE_FLAG="release"
    fi
    if ! USE_BAZEL=1 "${RUNNER[@]}" setup.py bdist_wheel $RELEASE_FLAG --quiet; then
        echo "Wheel generation failed! Running verbose wheel build to show errors..."
        USE_BAZEL=1 "${RUNNER[@]}" setup.py bdist_wheel $RELEASE_FLAG
        exit 1
    fi
    echo "Wheel generation completed successfully!"
    echo "Wheel available in: dist/"
fi

# Build documentation (optional)
if [[ "$1" == "--docs" ]]; then
    echo "Building documentation..."
    if ! command -v sphinx-build >/dev/null 2>&1; then
        echo "Error: sphinx-build not found."
        echo "Activate the virtual environment and re-run"
        exit 1
    fi
    if ! sphinx-build -M html docs/src build/docs -q; then
        echo "Documentation build failed!"
        exit 1
    fi
    echo "Documentation built successfully!"
    echo "HTML available in: build/docs/html/"
fi

if [[ "$1" != "--wheel" && "$1" != "--docs" ]]; then
    echo "To also generate a pip wheel, run: ./tools/build --wheel"
    echo "To build documentation, run: ./tools/build --docs"
fi
