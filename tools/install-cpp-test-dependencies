#!/bin/bash

# Script to install GTest and GMock dependencies for C++ unit tests
#
# Usage:
#   ./install-cpp-test-dependencies
#
# This script detects the OS and installs the appropriate GTest and GMock
# dependencies required for building and running C++ unit tests.

set -e  # Exit on any error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Function to install GTest and GMock dependencies
install_dependencies() {
    echo -e "${YELLOW}Installing GTest and GMock dependencies...${NC}"

    # Detect the OS
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS=$NAME
    elif type lsb_release >/dev/null 2>&1; then
        OS=$(lsb_release -si)
    else
        echo -e "${RED}Cannot detect OS. Please install libgtest-dev and libgmock-dev manually.${NC}"
        exit 1
    fi

    case "$OS" in
        *"Ubuntu"*|*"Debian"*)
            # Install and build gtest
            sudo apt-get update
            sudo apt-get install -y libgtest-dev libgmock-dev cmake build-essential
            cd /usr/src/googletest
            sudo cmake .
            sudo make
            sudo cp lib/*.a /usr/lib/ 2>/dev/null
            echo -e "${GREEN}Dependencies installed successfully!${NC}"
            # Return to original directory
            cd - > /dev/null
            ;;
        *"Amazon Linux"*)
            sudo yum install -y cmake gcc-c++
            # For Amazon Linux, need to build from source
            echo -e "${YELLOW}Amazon Linux detected. You need to build GTest from source.${NC}"
            ;;
        *)
            echo -e "${RED}Unsupported OS: $OS${NC}"
            echo -e "${YELLOW}Please install libgtest-dev and libgmock-dev manually.${NC}"
            exit 1
            ;;
    esac
}

# Main execution
echo -e "${BOLD}${YELLOW}Installing C++ test dependencies...${NC}"
install_dependencies
echo -e "${BOLD}${GREEN}Dependency installation completed!${NC}"
