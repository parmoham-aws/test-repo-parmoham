    name = "NConfigParserTest",
    srcs = ["profiler/NConfigParserTest.cpp"],
    size = "small",
    timeout = "short",
    copts = ["-I."],
    deps = [
        "//:nconfig_parser_lib",
        "@torch//:headers",
        "@torch//:libc10",
        "@googletest//:gtest_main",
    ],
)

