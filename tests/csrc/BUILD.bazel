# Test mocks library - shared mock sources for all tests
cc_library(
    name = "test_mocks",
    srcs = glob(["mocks/**/*.cpp"]),
    hdrs = glob(["mocks/**/*.h"]) +
        ["utils/TestUtils.h"],
    copts = [
        "-I.",
        "-Imocks",
        "-isystemexternal/torch",
        "-fvisibility=default",
    ],
    deps = [
        "//:device",
